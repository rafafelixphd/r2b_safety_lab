# R2B Safety Lab - Configuration
# Source this file in all scripts: source "$(dirname "$0")/config.env"

# --- User Configuration ---
export HF_USER="${HF_USER:-rafafelixphd}"
export DATASET_NAME="${DATASET_NAME:-dataset-trial-1}"
export POLICY_NAME="${POLICY_NAME:-policy-1}"
export WANDB_PROJECT="${WANDB_PROJECT:-lerobot-so101}"

# --- Directory layout ---
# Use absolute paths for robustness
export WORKSPACE_DIR="/workspace"
export REPO_DIR="${WORKSPACE_DIR}/bench/r2b_safety_lab"
export DATASET_ROOT="${WORKSPACE_DIR}/dataset"
export DATASET_DIR="${DATASET_ROOT}/${DATASET_NAME}"
export OUTPUT_ROOT="${WORKSPACE_DIR}/outputs/train"
export SSH_DIR="/root/.ssh"
export VENV_DIR="${WORKSPACE_DIR}/envs/.env"

# --- Git Configuration ---
export REPO_GIT_REF="${REPO_GIT_REF:-git@github.com:rafafelixphd/r2b_safety_lab.git}"
export REPO_BRANCH="dev"

# --- Colors for logging ---
# Only define if connected to a terminal
if [ -t 1 ]; then
    export RED='\033[0;31m'
    export GREEN='\033[0;32m'
    export YELLOW='\033[1;33m'
    export BLUE='\033[0;34m'
    export NC='\033[0m' # No Color
else
    export RED=''
    export GREEN=''
    export YELLOW=''
    export BLUE=''
    export NC=''
fi

# --- Helper Functions ---
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}
