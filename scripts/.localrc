#!/bin/bash

if [[ $SHELL == *"zsh"* ]]; then
    # macOS / zsh
    export PS1='%F{cyan}%n%f@%F{yellow}%1~%f %# '
else
    # Linux / bash
    export PS1='\[\033[36m\]\u\[\033[0m\]@\[\033[33m\]\W\[\033[0m\] \$ '
fi

if [ -d "/workspace/envs/.env" ]; then
    source /workspace/envs/.env/bin/activate
    echo "✓ Loaded '.localrc'"
else
    echo "✗ .env not found"
fi
